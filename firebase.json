{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "README-AR.md",
      "**/.*",
      "**/*.bak",
      "node_modules/**",
      "database.rules.json",
      ".env",
      ".env.*"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Permissions-Policy",
            "value": "camera=(self), microphone=()"
          },
          {
            "key": "Feature-Policy",
            "value": "camera 'self'; microphone 'none'"
          }
        ]
      },
      {
        "source": "service-worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|html|webmanifest)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      }
    ]
  }
}
