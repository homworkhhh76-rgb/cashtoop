# لا تضع كلمة المرور الحقيقية في هذا الملف عند رفع المشروع للمستخدمين.
# ضع القيم الحقيقية من لوحة الاستضافة (Environment Variables / Secrets) فقط.
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER_HOST>/<DB_NAME>?retryWrites=true&w=majority
MONGODB_DB=<EXISTING_DATABASE_NAME>
MONGODB_COLLECTION=cashtop_rtdb
CASHTOP_ALLOWED_ORIGINS=https://your-domain.example
